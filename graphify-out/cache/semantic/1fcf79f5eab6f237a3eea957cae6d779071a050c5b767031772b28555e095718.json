{"nodes": [{"id": "2026_05_16_hero_footer_redesign_design_spec", "label": "Hero & Footer Redesign Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-16-hero-footer-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_05_16_hero_footer_redesign_organic_dark_approved", "label": "Design Direction: Take 2 Organic Dark (Approved)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-16-hero-footer-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Approved design direction chosen from brainstorm: Take 2 \u2014 Organic Dark with Line Mask Reveal animation. Addresses problem that existing Hero and Footer share identical marquee watermarks, same #020617 gradient palette, gradient text fills, and generic glassmorphism \u2014 making them feel templated. Goal: clean, intentional, craft-forward design."}, {"id": "2026_05_16_hero_footer_redesign_design_principles", "label": "SoterCare Redesign Design Principles", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-16-hero-footer-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core principles: no gradient text fills; no marquee watermarks; no heavy overlay gradients; restrained accent color #a0cbdb max 1-2 uses per section; no generic glassmorphism \u2014 buttons are solid white or subtle border-only; animation serves content with every element having a reason."}, {"id": "2026_05_16_hero_footer_redesign_hero_redesign", "label": "Hero Component Redesign Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-16-hero-footer-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_05_16_hero_footer_redesign_footer_redesign", "label": "Footer Component Redesign Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-16-hero-footer-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_05_16_hero_footer_redesign_gsap_animation_sequence", "label": "Hero GSAP Animation Sequence", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-16-hero-footer-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sequenced via single GSAP timeline on mount: glow orb (0s, power2.out), pill tag (0.1s), headline line 1 (0.2s), line 2 (0.32s), line 3 (0.44s), descriptor (0.56s), CTA group (0.64s), stats (0.72s). Line reveals 0.75s duration, fades 0.5s. All use power3.out. Scroll-exit via ScrollTrigger scrub scaling hero to 0.8."}, {"id": "2026_05_16_hero_footer_redesign_shared_design_tokens", "label": "Shared Design Tokens (Hero & Footer)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-05-16-hero-footer-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tokens: --bg-dark #080b14 for hero+footer background; --accent #a0cbdb for pill/glow max 1 per section; --text-faded-1 rgba(255,255,255,0.22) for headline line 3; --text-faded-2 rgba(255,255,255,0.15) for footer 'Simplified.'; --text-dim rgba(255,255,255,0.30) for descriptors; --border-subtle rgba(255,255,255,0.08) for structural dividers."}, {"id": "2026_05_16_hero_footer_redesign_sotercare_product", "label": "SoterCare \u2014 IoT Elderly Care Monitoring Product", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-05-16-hero-footer-redesign-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "2026_05_16_hero_footer_redesign_hero_