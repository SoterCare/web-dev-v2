{"nodes": [{"id": "1126_1778937276_animation_style_gsap_animation_style", "label": "GSAP Animation Style (brainstorm 1126)", "file_type": "document", "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "1126_1778937276_animation_style_line_mask_reveal", "label": "Animation A \u2014 Line Mask Reveal", "file_type": "rationale", "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each text line slides up from a hidden clip container (overflow:hidden). Most-used technique in premium agency sites. Polished and editorial. Implemented with GSAP SplitText or manual overflow:hidden divs per line. Uses cubic-bezier(0.16,1,0.3,1) easing with staggered delays."}, {"id": "1126_1778937276_animation_style_word_float", "label": "Animation B \u2014 Word Float (Springy)", "file_type": "rationale", "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each word bounces up with a slight spring overshoot using rotateX(30deg) and translateY. More playful and energetic than mask reveal. Uses GSAP stagger with power2.out or elastic ease. Cubic-bezier(0.34,1.56,0.64,1) for spring effect."}, {"id": "1126_1778937276_animation_style_cinematic_blur_bloom", "label": "Animation C \u2014 Cinematic Blur Bloom", "file_type": "rationale", "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Text fades in from blurred, slightly scaled-down state \u2014 like camera pulling into focus. Background glow blooms as text clears. Atmospheric and premium. Uses GSAP with filter:blur() and scale. GlowBloom keyframe scales orb from 0.2 to 1.3 with opacity fade."}, {"id": "concept_gsap_library", "label": "GSAP Animation Library", "file_type": "concept", "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "1126_1778937276_animation_style_gsap_animation_style", "target": "1126_1778937276_animation_style_line_mask_reveal", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "weight": 1.0}, {"source": "1126_1778937276_animation_style_gsap_animation_style", "target": "1126_1778937276_animation_style_word_float", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "weight": 1.0}, {"source": "1126_1778937276_animation_style_gsap_animation_style", "target": "1126_1778937276_animation_style_cinematic_blur_bloom", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "weight": 1.0}, {"source": "1126_1778937276_animation_style_gsap_animation_style", "target": "concept_gsap_library", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "hyperedge_brainstorm_animation_options", "label": "Three Animation Option Brainstorm (both sessions)", "nodes": ["1126_1778937276_animation_style_line_mask_reveal", "1126_1778937276_animation_style_word_float", "1126_1778937276_animation_style_cinematic_blur_bloom"], "relation": "participate_in", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".superpowers/brainstorm/1126-1778937276/content/animation-style.html"}]}