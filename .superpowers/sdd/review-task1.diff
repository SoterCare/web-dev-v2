   if (!DATE_RE.test(art.date as string)) {
     throw new Error(`Article[${i}].date must match YYYY-MM-DD, got "${art.date}"`);
   }
   if (!Array.isArray(art.tags) || art.tags.some((t) => typeof t !== 'string')) {
